{
  "name": "@llp-design/tokens",
  "version": "0.2.0",
  "description": "LLP design tokens — W3C DTCG source of truth, built with Style Dictionary",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WildDog7000/design-infra.git",
    "directory": "packages/tokens"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "tokens"
  ],
  "exports": {
    ".": "./dist/ts/tokens.js",
    "./css": "./dist/css/tokens.css",
    "./css/dark": "./dist/css/tokens.dark.css",
    "./json": "./dist/json/tokens.flat.json",
    "./tokens/*": "./tokens/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "import:spectrum": "node scripts/import-spectrum.mjs",
    "build": "node build.js",
    "clean": "rm -rf dist",
    "release": "node scripts/release.mjs",
    "release:diff": "node scripts/release-diff.mjs"
  },
  "devDependencies": {
    "@adobe/spectrum-tokens": "^14.13.2",
    "style-dictionary": "^5.5.0"
  }
}
